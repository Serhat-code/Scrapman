# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<votre-projet>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<remplacer-par-votre-cle-anon-supabase>

# Clé service_role Supabase (Project Settings > API). SERVEUR UNIQUEMENT —
# ne jamais exposer côté client. Utilisée pour générer les liens de
# confirmation d'inscription / réinitialisation de mot de passe sans passer
# par l'envoi d'email intégré de Supabase (on envoie nous-mêmes via Resend).
SUPABASE_SERVICE_ROLE_KEY=<remplacer-par-votre-cle-service-role-supabase>

# Resend (email transactionnel plateforme : confirmation inscription, reset
# mdp, invitations — distinct du SMTP que chaque équipe configure pour SA
# prospection). Compte gratuit sur resend.com (100 emails/jour).
RESEND_API_KEY=<remplacer-par-votre-cle-resend>
# Optionnel : adresse d'expéditeur une fois un domaine vérifié sur Resend.
# Sans domaine vérifié, garder onboarding@resend.dev (mode test).
RESEND_FROM_EMAIL=Scrapman <onboarding@resend.dev>

# Stripe (facturation). Clé secrète en mode test depuis le dashboard Stripe ;
# clé de signature webhook générée lors de la création de l'endpoint
# (dashboard Stripe ou `stripe listen` en local).
STRIPE_SECRET_KEY=<remplacer-par-votre-cle-secrete-stripe>
STRIPE_WEBHOOK_SECRET=<remplacer-par-votre-secret-webhook-stripe>

# Config Scrapman
NEXT_PUBLIC_VILLE_PROSPECTEUR=Saint-Étienne
NEXT_PUBLIC_CALENDLY_URL=calendly.com/atlamazstudio/30min

# Chiffrement du mot de passe SMTP (AES-256-GCM, 32 octets en hexadécimal)
# Génération : openssl rand -hex 32
SMTP_ENCRYPTION_KEY=
