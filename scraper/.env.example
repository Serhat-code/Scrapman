# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# INSEE (optionnel - fallback auto data.gouv si absent)
INSEE_API_KEY=

# Config
SCRAPMAN_DEFAULT_USER_ID=uuid-de-test
VILLE_PROSPECTEUR=Saint-Étienne
CALENDLY_URL=calendly.com/atlamazstudio/30min

# Chiffrement SMTP — DOIT être strictement identique à SMTP_ENCRYPTION_KEY
# défini dans frontend/.env.local (généré par le frontend lors du chiffrement,
# déchiffré ici par le worker). Génération : openssl rand -hex 32
SMTP_ENCRYPTION_KEY=
